[Unit]
Description=Pet feeder weight jam monitor
After=network-online.target time-sync.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/weight_monitor
ExecStart=/home/pi/weight_monitor/.venv/bin/wm-daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
